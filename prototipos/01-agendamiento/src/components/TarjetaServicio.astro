---
const { nombre, descripcion, precio } = Astro.props;
---
<article class="border border-slate-200 rounded-xl p-6 text-center hover:shadow-lg transition-shadow">
  <h3 class="text-xl font-semibold mb-2">{nombre}</h3>
  <p class="text-slate-500 mb-4">{descripcion}</p>
  <span class="text-2xl font-bold text-amber-500">{precio}</span>
</article>