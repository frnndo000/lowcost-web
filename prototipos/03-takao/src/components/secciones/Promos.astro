---
// Las promos por día son de lo más preguntado por Instagram y ningún
// competidor las tiene publicadas. Es contenido de alto valor para SEO
// ("promociones sushi Viña del Mar") y para conversión.
import { promos } from "../../data/carta.js";

const columnas = [
  { titulo: "Cocina", items: promos.cocina, color: "text-marca-texto", linea: "bg-marca" },
  { titulo: "Barra", items: promos.bar, color: "text-acento", linea: "bg-acento" },
];
---

<section id="promos" class="border-y border-borde bg-superficie">
  <div class="mx-auto max-w-5xl px-5 py-16">
    <header class="mb-10 text-center">
      <h2 class="titulo-carta text-4xl font-semibold sm:text-5xl">
        Promociones
      </h2>
      <p class="mt-4 text-texto-suave">Una distinta cada día, de lunes a viernes.</p>
    </header>

    <div class="grid gap-10 sm:grid-cols-2">
      {
        columnas.map((columna) => (
          <div>
            <h3 class={`titulo-carta mb-1 text-xl font-semibold ${columna.color}`}>
              {columna.titulo}
            </h3>
            <div class={`mb-4 h-px w-12 ${columna.linea}`} />
            <ul class="space-y-3">
              {columna.items.map((promo) => (
                <li class="flex items-baseline gap-4 border-b border-borde py-2">
                  <div class="min-w-0">
                    <span class="block text-xs uppercase tracking-widest text-texto-suave">
                      {promo.dia}
                    </span>
                    <span class="text-texto">{promo.titulo}</span>
                    {promo.nota && (
                      <span class="block text-xs text-texto-suave">
                        {promo.nota}
                      </span>
                    )}
                  </div>
                  <span class="ml-auto shrink-0 font-semibold tabular-nums text-precio">
                    {promo.oferta}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
