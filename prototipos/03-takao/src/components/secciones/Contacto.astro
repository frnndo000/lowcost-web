---
import { negocio, textoDias } from "../../data/negocio.js";

const whatsapp = `https://wa.me/${negocio.whatsapp}?text=${encodeURIComponent(negocio.mensajeWhatsapp)}`;

// El mapa se arma con la búsqueda, sin API key ni costo. Cuando el dueño
// confirme la dirección exacta este mismo embed la toma automáticamente.
const consultaMapa = encodeURIComponent(
  `${negocio.nombre} ${negocio.direccion} ${negocio.comuna}`,
);
---

<section id="ubicacion" class="border-t border-borde bg-superficie">
  <div class="mx-auto max-w-5xl px-5 py-16">
    <header class="mb-10 text-center">
      <h2 class="titulo-carta text-4xl font-semibold sm:text-5xl">
        Dónde estamos
      </h2>
      <p class="mx-auto mt-4 max-w-md text-texto-suave">
        Pide directo por WhatsApp y te tomamos el pedido al tiro. Retiro en
        local o delivery.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      <div class="space-y-4">
        <div class="rounded-suave border border-borde p-6">
          <h3 class="mb-2 text-xs uppercase tracking-widest text-texto-suave">
            Dirección
          </h3>
          <address class="text-lg">
            {negocio.direccion}<br />
            {negocio.comuna}, {negocio.region}
          </address>
        </div>

        <div class="rounded-suave border border-borde p-6">
          <h3 class="mb-3 text-xs uppercase tracking-widest text-texto-suave">
            Horario
          </h3>
          <ul class="space-y-2">
            {
              negocio.horario.map((bloque) => (
                <li class="flex justify-between gap-4">
                  <span>{textoDias(bloque.dias)}</span>
                  <span class="tabular-nums text-texto-suave">
                    {bloque.abre} – {bloque.cierra}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <a
            href={whatsapp}
            target="_blank"
            rel="noopener"
            class="rounded-suave border border-borde p-5 text-center transition-colors hover:border-marca"
          >
            <p class="font-semibold">WhatsApp</p>
            <p class="mt-1 text-xs text-texto-suave">{negocio.telefono}</p>
          </a>
          <a
            href={`https://instagram.com/${negocio.instagram}`}
            target="_blank"
            rel="noopener"
            class="rounded-suave border border-borde p-5 text-center transition-colors hover:border-marca"
          >
            <p class="font-semibold">Instagram</p>
            <p class="mt-1 text-xs text-texto-suave">@{negocio.instagram}</p>
          </a>
        </div>

        <a
          href={whatsapp}
          target="_blank"
          rel="noopener"
          class="block rounded-suave bg-marca px-6 py-4 text-center text-lg font-semibold transition-colors hover:bg-marca-hover"
        >
          Hacer mi pedido
        </a>
      </div>

      <div class="overflow-hidden rounded-suave border border-borde">
        <iframe
          src={`https://www.google.com/maps?q=${consultaMapa}&output=embed`}
          width="100%"
          height="100%"
          style="border:0; min-height:420px;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Ubicación de ${negocio.nombre} en ${negocio.comuna}`}></iframe>
      </div>
    </div>
  </div>
</section>
