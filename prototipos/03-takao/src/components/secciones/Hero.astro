---
// Fondo: foto de la carta desenfocada a 96 px de ancho (0,8 KB). El
// desenfoque esconde justamente la baja resolución del recorte, así que
// aporta luz cálida sin que se note de dónde salió. Cuando lleguen las
// fotos en alta del dueño, se regenera desde una de ellas.
import { Image } from "astro:assets";
import Logo from "../Logo.astro";
import { negocio } from "../../data/negocio.js";
import fondo from "../../assets/hero-fondo.jpg";

const whatsapp = `https://wa.me/${negocio.whatsapp}?text=${encodeURIComponent(negocio.mensajeWhatsapp)}`;
---

<section id="inicio" class="relative overflow-hidden border-b border-borde">
  <Image
    src={fondo}
    alt=""
    aria-hidden="true"
    width={1200}
    height={1060}
    loading="eager"
    class="absolute inset-0 h-full w-full scale-110 object-cover opacity-40"
  />
  <!-- Velos: mantienen legible el texto y funden la foto con el fondo. -->
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_10%,var(--color-fondo)_75%)]"
  >
  </div>
  <div class="absolute inset-0 bg-fondo/45"></div>

  <!-- Kanji 寿司 (sushi), en vertical y en mincho. Decorativo. -->
  <span
    aria-hidden="true"
    class="kanji absolute right-4 top-8 hidden text-[11rem] leading-none text-texto/8 sm:block lg:right-16 lg:text-[15rem]"
    >寿司</span
  >

  <div
    class="relative mx-auto flex max-w-3xl flex-col items-center gap-6 px-5 py-20 text-center sm:py-28"
  >
    <Logo tamano={104} conTexto={false} />

    <div>
      <h1 class="titulo-carta text-5xl font-semibold tracking-[0.15em] drop-shadow-lg sm:text-7xl">
        TAKAO
      </h1>
      <p class="mt-1 text-sm uppercase tracking-[0.5em] text-marca sm:text-base">
        Sushi Bar
      </p>
    </div>

    <p class="max-w-lg text-lg text-texto-suave drop-shadow">
      {negocio.descripcion}
    </p>

    <ul class="flex flex-wrap justify-center gap-2">
      {
        negocio.atributos.map((a) => (
          <li class="rounded-full border border-borde bg-fondo/70 px-3 py-1.5 text-sm text-texto-suave backdrop-blur-sm">
            <span aria-hidden="true">{a.icono}</span> {a.texto}
          </li>
        ))
      }
    </ul>

    <div class="mt-2 flex w-full flex-col gap-3 sm:w-auto sm:flex-row">
      <a
        href={whatsapp}
        target="_blank"
        rel="noopener"
        class="rounded-suave bg-marca px-8 py-4 text-lg font-semibold shadow-lg shadow-marca/25 transition-colors hover:bg-marca-hover"
      >
        Pedir por WhatsApp
      </a>
      <a
        href="/carta"
        class="rounded-suave border border-borde bg-fondo/60 px-8 py-4 text-lg font-semibold backdrop-blur-sm transition-colors hover:border-texto-suave"
      >
        Ver la carta
      </a>
    </div>
  </div>
</section>
