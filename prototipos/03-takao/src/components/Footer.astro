---
import { negocio, textoDias } from "../data/negocio.js";
---

<footer class="border-t border-borde bg-superficie">
  <div class="mx-auto grid max-w-5xl gap-8 px-5 py-12 sm:grid-cols-3">
    <div class="space-y-1">
      <p class="titulo-carta text-lg font-semibold tracking-[0.2em]">TAKAO</p>
      <p class="text-sm text-texto-suave">{negocio.direccion}</p>
      <p class="text-sm text-texto-suave">{negocio.comuna}, {negocio.region}</p>
      <p class="text-sm text-texto-suave">{negocio.telefono}</p>
      <p>
        <a
          href={`https://instagram.com/${negocio.instagram}`}
          target="_blank"
          rel="noopener"
          class="text-sm text-precio transition-colors hover:text-texto"
        >
          @{negocio.instagram}
        </a>
      </p>
    </div>

    <div>
      <h2 class="mb-2 text-xs uppercase tracking-widest text-texto-suave">
        Horario
      </h2>
      <ul class="space-y-1">
        {
          negocio.horario.map((bloque) => (
            <li class="flex justify-between gap-4 text-sm">
              <span class="text-texto">{textoDias(bloque.dias)}</span>
              <span class="tabular-nums text-texto-suave">
                {bloque.abre} – {bloque.cierra}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="mb-2 text-xs uppercase tracking-widest text-texto-suave">
        También en delivery
      </h2>
      <ul class="space-y-1 text-sm">
        {
          negocio.canales.ubereats && (
            <li>
              <a
                href={negocio.canales.ubereats}
                target="_blank"
                rel="noopener"
                class="text-texto-suave transition-colors hover:text-texto"
              >
                Uber Eats
              </a>
            </li>
          )
        }
        {
          negocio.canales.pedidosya && (
            <li>
              <a
                href={negocio.canales.pedidosya}
                target="_blank"
                rel="noopener"
                class="text-texto-suave transition-colors hover:text-texto"
              >
                PedidosYa
              </a>
            </li>
          )
        }
      </ul>
      <p class="mt-3 text-xs leading-relaxed text-texto-suave">
        Pidiendo directo por WhatsApp el precio es el de la carta: las apps
        cobran comisión.
      </p>
    </div>
  </div>

  <div class="border-t border-borde px-5 py-6 text-center text-xs text-texto-suave">
    <p>&copy; {new Date().getFullYear()} {negocio.nombre} · {negocio.comuna}</p>
    <p class="mt-1">Venta de alcohol solo a mayores de 18 años.</p>
  </div>
</footer>
