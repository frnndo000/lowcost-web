---
// El hexágono de la marca, recortado del logo oficial y con el fondo negro
// vuelto transparente. Sin el texto "TAKAO SUSHI BAR" del logo circular:
// al lado del wordmark del header quedaría el nombre repetido dos veces.
//
// Va por <Image> de astro:assets: cada uso recibe su tamaño en webp.
// Para cambiar el logo basta reemplazar src/assets/logo-rojo.png.
import { Image } from "astro:assets";
import { logo } from "../data/imagenes.js";

interface Props {
  tamano?: number;
  variante?: "rojo" | "azul";
  conTexto?: boolean;
  class?: string;
}

const {
  tamano = 44,
  variante = "rojo",
  conTexto = true,
  class: clase = "",
} = Astro.props;

// El hexágono es más alto que ancho (proporción del original: 640×743).
const alto = Math.round((tamano * 743) / 640);
---

<span class={`flex items-center gap-3 ${clase}`}>
  <Image
    src={logo[variante]}
    alt="Takao Sushi Bar"
    width={tamano}
    height={alto}
    densities={[1, 2]}
    loading="eager"
    class="shrink-0 object-contain"
  />
  {
    conTexto && (
      <span class="titulo-carta text-xl font-semibold leading-none tracking-[0.2em]">
        TAKAO
      </span>
    )
  }
</span>
