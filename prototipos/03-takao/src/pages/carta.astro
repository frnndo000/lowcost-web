---
// Página propia para la cocina. Separarla de la barra no es solo por largo:
// "carta sushi Viña del Mar" y "bar Viña del Mar" son búsquedas distintas,
// y con dos URLs competimos por las dos.
import Layout from "../layouts/Layout.astro";
import Carta from "../components/secciones/Carta.astro";
import { negocio } from "../data/negocio.js";
---

<Layout
  titulo={`Carta — ${negocio.nombre}, ${negocio.comuna}`}
  descripcion="Carta completa de Takao Sushi Bar: rolls, gohan, ceviches, sushi burgers, hamburguesas, tablas y chorrillanas. Precios directos, sin comisión de app."
>
  <header class="border-b border-borde px-5 py-12 text-center">
    <p class="text-xs uppercase tracking-[0.3em] text-marca-texto">Cocina</p>
    <h1 class="titulo-carta mt-2 text-4xl font-semibold sm:text-5xl">Carta</h1>
    <p class="mx-auto mt-4 max-w-lg text-texto-suave">
      Precios de la carta directa. Pidiendo por WhatsApp no pagas comisión de
      app.
    </p>
  </header>

  <Carta grupo="cocina" />
</Layout>
