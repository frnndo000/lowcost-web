---
import { Image } from "astro:assets";
import consulta from "../../assets/consulta.jpg";
import { negocio, sobreMi } from "../../data/datos.js";
const { stats } = negocio;
const { intro, hitos } = sobreMi;
---
<section id="sobre-mi" class="bg-white py-28 px-6">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 md:gap-16">

<!-- COLUMNA IZQUIERDA: foto sticky -->
<div class="md:sticky md:top-28 md:self-start">

  <!-- MÓVIL: foto + stats al costado / ESCRITORIO: apilados -->
  <div class="flex md:block gap-5 items-center">

    <!-- Foto -->
    <div class="relative w-[55%] shrink-0 md:w-full">
      <div class="absolute -inset-2.5 md:-inset-5 bg-marca-suave rounded-3xl md:rounded-[3rem] rotate-3"></div>
      <Image src={consulta}
       alt="Tamara atendiendo en consulta"
       class="relative w-full aspect-3/4 md:aspect-4/5 object-cover rounded-[1.25rem] md:rounded-4xl shadow-xl" />
    </div>

    <!-- Stats -->
    <div class="flex-1 flex flex-col gap-5 md:grid md:grid-cols-3 md:gap-4 md:mt-10">
      {stats.map((s, i) => (
        <div class="group cursor-default">
          <p class:list={["font-display font-semibold text-4xl transition-transform duration-300 group-hover:scale-110 origin-left", i === stats.length - 1 ? "text-marca" : "text-neutral-900"]}>{s.num}</p>
          <p class="text-[11px] uppercase tracking-widest text-neutral-400 mt-1 leading-tight">{s.etiqueta}</p>
        </div>
      ))}
    </div>

  </div>
</div>
      <!-- COLUMNA DERECHA: timeline -->
      <div>
        <p class="text-marca text-xs font-semibold uppercase tracking-widest mb-4">Sobre mí</p>
        <h2 class="text-neutral-900 font-display font-semibold text-4xl md:text-5xl leading-tight mb-6">
          Detrás del plan<br/>hay una persona
        </h2>
        <p class="text-neutral-600 text-lg leading-relaxed mb-12">
          {intro}
        </p>

        <div class="space-y-0">
          {hitos.map(h => (
            <div class="group border-l-2 border-neutral-200 hover:border-marca pl-8 py-7 transition-colors duration-300 relative">

            <!-- Punto en la línea -->
            <span class="absolute -left-1.75 top-9 w-3 h-3 rounded-full bg-neutral-200
                        group-hover:bg-marca group-hover:scale-125 transition-all duration-300"></span>

            <p class="text-[11px] uppercase tracking-widest text-neutral-400 mb-1">{h.etiqueta}</p>
            <h3 class="text-lg font-bold text-neutral-900">{h.titulo}</h3>

            <!-- Móvil: siempre visible · Escritorio: se despliega al hacer hover -->
            <p class="text-neutral-600 text-sm leading-relaxed mt-3
                      md:mt-0 md:max-h-0 md:opacity-0 md:overflow-hidden
                      md:group-hover:max-h-40 md:group-hover:opacity-100 md:group-hover:mt-3
                      transition-all duration-500">
              {h.detalle}
            </p>
          </div>
        ))}
      </div>
        <p class="text-neutral-400 text-xs mt-8 md:block hidden">
          ↑ Pasa el cursor sobre cada punto para ver más
        </p>
      </div>

    </div>
  </section>
