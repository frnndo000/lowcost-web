---
import { negocio, wa } from "../../data/datos.js";
const { ubicacion, instagram, horario } = negocio;
const mapaSrc = `https://www.google.com/maps?q=${encodeURIComponent(ubicacion.mapsQuery)}&output=embed`;
const instagramUrl = `https://www.instagram.com/${instagram}/`;
---
<section id="contacto" class="bg-neutral-50 py-28 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="max-w-2xl mb-14">
      <p class="text-marca text-xs font-semibold uppercase tracking-widest mb-4">Contacto</p>
      <h2 class="text-neutral-900 font-display font-semibold text-4xl md:text-5xl leading-tight mb-4">
        Nos vemos en consulta
      </h2>
      <p class="text-neutral-600 text-lg">
        Agenda tu hora por <a href={wa()} target="_blank" rel="noopener" class="text-marca hover:underline">WhatsApp</a>; ahí resolvemos cualquier duda antes de empezar.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

      <!-- Datos -->
      <div class="space-y-4">

        <div class="group bg-white border border-neutral-200 rounded-3xl p-7 hover:border-marca/30 hover:shadow-lg transition-all duration-300">
          <p class="text-[11px] uppercase tracking-widest text-neutral-400 mb-2">Ubicación</p>
          <p class="text-neutral-900 font-bold text-lg mb-1">{ubicacion.edificio}</p>
          <p class="text-neutral-600 text-sm">{ubicacion.direccion}, {ubicacion.comuna}, {ubicacion.region}</p>
          {ubicacion.online && (
            <p class="text-marca text-sm mt-2 font-semibold">También atención online en todo Chile</p>
          )}
        </div>

        <div class="group bg-white border border-neutral-200 rounded-3xl p-7 hover:border-marca/30 hover:shadow-lg transition-all duration-300">
          <p class="text-[11px] uppercase tracking-widest text-neutral-400 mb-3">Horario de atención</p>
          {horario ? (
            <p class="text-neutral-900 font-bold text-lg">Consulta la disponibilidad por WhatsApp</p>
          ) : (
            <>
              <p class="text-neutral-900 font-bold text-lg mb-2">Coordina tu hora por WhatsApp</p>
              <p class="text-neutral-500 text-sm leading-relaxed">
                Reservas y cupos disponibles se gestionan directamente por mensaje. Te respondo lo antes posible.
              </p>
            </>
          )}
        </div>

        <div class="grid grid-cols-2 gap-4">
          <a href={wa()} target="_blank" rel="noopener"
             class="bg-white border border-neutral-200 rounded-3xl p-6 text-center hover:border-marca hover:-translate-y-1 transition-all duration-300">
            <p class="text-neutral-900 font-bold">WhatsApp</p>
            <p class="text-neutral-500 text-xs mt-1">Agenda y dudas</p>
          </a>
          <a href={instagramUrl} target="_blank" rel="noopener"
             class="bg-white border border-neutral-200 rounded-3xl p-6 text-center hover:border-marca hover:-translate-y-1 transition-all duration-300">
            <p class="text-neutral-900 font-bold">Instagram</p>
            <p class="text-neutral-500 text-xs mt-1">@{instagram}</p>
          </a>
        </div>

        <a href={wa()} target="_blank" rel="noopener"
           class="group block bg-marca text-white rounded-3xl p-7 hover:bg-acento transition-colors">
          <p class="text-[11px] uppercase tracking-widest text-white/70 mb-2">Reservar</p>
          <p class="font-bold text-lg flex items-center gap-2">
            Agendar por WhatsApp
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </p>
        </a>
      </div>

      <!-- Mapa -->
      <div class="rounded-3xl overflow-hidden border border-neutral-200 min-h-100">
        <iframe
          src={mapaSrc}
          width="100%" height="100%" style="border:0; min-height:400px;"
          allowfullscreen="" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Ubicación de ${ubicacion.edificio} en ${ubicacion.comuna}`}>
        </iframe>
      </div>

    </div>
  </div>
</section>
