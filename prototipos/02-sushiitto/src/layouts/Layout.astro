---
// Marco compartido de todas las páginas: el <head>, el header y el footer.
// El contenido único de cada página entra por el <slot />.
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { local } from "../data/local.js";
import "../styles/global.css";
import WhatsAppFlotante from "../components/WhatsAppFlotante.astro";

const { titulo = `${local.nombre} — ${local.bajada}` } = Astro.props;
---

<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titulo}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Zen+Kaku+Gothic+New:wght@500;700&family=Yuji+Syuku&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppFlotante />
  </body>
</html>