---
import { local } from "../data/local.js";
---

<header class="sticky top-0 z-20 border-b border-borde bg-fondo/90 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
    <a href="/" class="flex shrink-0 items-center gap-3">
      <img
        src="/imagenes/logo.jpg"
        alt="SUSHIITTO — sushi en Viña del Mar"
        width="48"
        height="48"
        class="h-12 w-12 rounded-full"
      />
      <span class="font-display text-xl font-bold tracking-wide">
        <span class="text-texto">SUSHI</span><span class="text-rojo">ITTO</span>
      </span>
    </a>
   
    <nav>
      <ul class="flex items-center gap-4 pl-4 text-sm text-texto-suave sm:gap-6">
        <li><a href="#menu" class="transition-colors hover:text-texto">Carta</a></li>
        <li><a href="#contacto" class="transition-colors hover:text-texto">Contacto</a></li>
        <li><a href="#ubicacion" class="transition-colors hover:text-texto">Ubicación</a></li>
      </ul>
    </nav>
  </div>
</header>