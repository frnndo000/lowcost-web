---
// El menú móvil usa la Popover API nativa: cierra con Esc y con clic
// afuera sin una sola línea de JavaScript. `popover` sin valor es
// `popover="auto"`, que es el que trae el cierre por clic afuera.
import Logo from "./Logo.astro";

const enlaces = [
  { href: "/carta", texto: "Carta" },
  { href: "/bar", texto: "Bar" },
  { href: "/#sucursales", texto: "Sucursales" },
  { href: "/#preguntas", texto: "Preguntas" },
];

// Marca la página actual.
const aqui = Astro.url.pathname.replace(/\/$/, "") || "/";
const esActual = (href) => href === aqui;
---

<header
  class="sticky top-0 z-20 border-b border-borde bg-fondo/90 backdrop-blur"
>
  <div class="mx-auto flex max-w-5xl items-center gap-4 px-5 py-3">
    <a
      href="/"
      class="mr-auto flex shrink-0 items-center gap-3"
      aria-label="Patio 511, inicio"
    >
      <Logo tamano={40} />
      <span
        class="titulo-carta hidden text-lg font-semibold leading-none sm:inline"
      >
        Patio 511
      </span>
    </a>

    <nav class="hidden md:block" aria-label="Principal">
      <ul class="flex items-center gap-6 text-sm">
        {
          enlaces.map((e) => (
            <li>
              <a
                href={e.href}
                aria-current={esActual(e.href) ? "page" : undefined}
                class:list={[
                  "transition-colors hover:text-texto",
                  esActual(e.href)
                    ? "text-texto underline decoration-marca decoration-2 underline-offset-8"
                    : "text-texto-suave",
                ]}
              >
                {e.texto}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      href="/#pedir"
      class="hidden shrink-0 rounded-suave bg-marca px-5 py-2.5 text-sm font-semibold text-fondo transition-colors hover:bg-marca-hover md:inline-block"
    >
      Pide aquí
    </a>

    <button
      type="button"
      popovertarget="menu-movil"
      aria-label="Abrir menú"
      class="flex h-10 w-10 items-center justify-center rounded-suave border border-borde md:hidden"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M3 6h18M3 12h18M3 18h18"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  <div id="menu-movil" popover class="menu-movil">
    <nav aria-label="Menú móvil">
      <ul class="flex flex-col gap-1">
        {
          enlaces.map((e) => (
            <li>
              <a
                href={e.href}
                aria-current={esActual(e.href) ? "page" : undefined}
                class:list={[
                  "block rounded-suave px-4 py-3 text-lg transition-colors hover:bg-fondo",
                  esActual(e.href) && "text-marca-texto",
                ]}
              >
                {e.texto}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a
      href="/#pedir"
      class="mt-4 block rounded-suave bg-marca px-4 py-3 text-center font-semibold text-fondo"
    >
      Pide aquí
    </a>
    <button
      type="button"
      popovertarget="menu-movil"
      popovertargetaction="hide"
      class="mt-2 w-full px-4 py-2 text-sm text-texto-suave"
    >
      Cerrar
    </button>
  </div>
</header>

<style>
  /* El preflight de Tailwind pone `margin: 0` en todo, lo que anula el
     `margin: auto` con que el navegador centra los popover. Se posiciona
     a mano: panel anclado bajo el header. */
  .menu-movil {
    position: fixed;
    inset: 4.75rem 1.25rem auto 1.25rem;
    width: auto;
    max-height: calc(100dvh - 6rem);
    overflow-y: auto;
    padding: 1rem;
    border: 1px solid var(--color-borde);
    border-radius: var(--radius-suave);
    background-color: var(--color-superficie);
    color: var(--color-texto);
  }

  .menu-movil::backdrop {
    background-color: rgb(0 0 0 / 0.6);
    backdrop-filter: blur(2px);
  }
</style>
