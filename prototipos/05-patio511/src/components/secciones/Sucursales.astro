---
// Las dos sucursales, con selector: antes se veían los dos mapas apilados,
// lo que duplicaba la "doble sucursal". Ahora un toggle Reñaca | Quilpué
// muestra UN mapa a la vez (mapa + dirección + ambiente + horario).
//
// Mismo switcher CSS puro que "Pide aquí": radios ocultos + `:has()`, con
// las reglas generadas desde el array `sucursales` (agregar una tercera es
// solo datos). Los dos paneles quedan en el HTML para Google.
//
// El mapa se arma con la búsqueda, sin API key ni costo. Cuando el dueño
// confirme las coords exactas, este mismo embed las toma.
import { sucursales, textoDias, consultaMapa } from "../../data/negocio.js";

const cssSwitcher = sucursales
  .map(
    (s) =>
      `.sel-mapa:has(input[value="${s.id}"]:checked) [data-panel="${s.id}"]{display:block}`,
  )
  .join("\n");
---

<section id="sucursales" class="border-t border-borde">
  <div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
    <header class="mb-8 max-w-xl">
      <h2 class="titulo-carta text-titulo">Dos patios</h2>
      <p class="mt-3 text-texto-suave">
        Reñaca y Quilpué, cada uno con su propio ambiente y horario.
      </p>
    </header>

    <div class="sel-mapa">
      <fieldset class="mb-6">
        <legend class="sr-only">Elige la sucursal</legend>
        <div class="inline-flex rounded-full border border-borde p-1">
          {
            sucursales.map((s, i) => (
              <label class="cursor-pointer">
                <input
                  type="radio"
                  name="sel-mapa"
                  value={s.id}
                  checked={i === 0}
                  class="peer sr-only"
                />
                <span class="block rounded-full px-5 py-2 text-sm font-medium text-texto-suave transition-colors peer-checked:bg-marca peer-checked:font-semibold peer-checked:text-fondo peer-focus-visible:ring-2 peer-focus-visible:ring-marca-texto">
                  {s.nombre}
                </span>
              </label>
            ))
          }
        </div>
      </fieldset>

      {
        sucursales.map((s) => (
          <article
            data-panel={s.id}
            id={`suc-${s.id}`}
            class="scroll-ancla hidden overflow-hidden rounded-suave border border-borde bg-superficie"
          >
            <div class="grid sm:grid-cols-2">
              <div class="relative min-h-[240px] border-b border-borde sm:min-h-[340px] sm:border-b-0 sm:border-r">
                <iframe
                  src={`https://www.google.com/maps?q=${consultaMapa(s)}&output=embed`}
                  class="absolute inset-0 h-full w-full"
                  style="border:0; display:block;"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`Ubicación de Patio 511 ${s.nombre}`}
                />
              </div>

              <div class="space-y-5 p-6 sm:p-7">
                <div>
                  <h3 class="titulo-carta text-sub">{s.nombre}</h3>
                  <address class="mt-1 text-texto-suave">
                    {s.direccion}
                    <br />
                    {s.comuna}, Región de Valparaíso
                  </address>
                  {s.referencia && (
                    <p class="mt-1 text-sm text-marca-texto">{s.referencia}</p>
                  )}
                </div>

                <p class="text-sm leading-relaxed text-texto-suave">
                  {s.ambiente}
                </p>

                <div>
                  <h4 class="mb-2 text-xs uppercase tracking-widest text-texto-suave">
                    Horario
                  </h4>
                  <ul class="space-y-1">
                    {s.horario.map((bloque) => (
                      <li class="flex justify-between gap-4 text-sm">
                        <span>{textoDias(bloque.dias)}</span>
                        <span class="tabular-nums text-texto-suave">
                          {bloque.abre} – {bloque.cierra}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-texto-suave">
                  <a
                    href={`https://www.google.com/maps/search/?api=1&query=${consultaMapa(s)}`}
                    target="_blank"
                    rel="noopener"
                    class="transition-colors hover:text-texto"
                  >
                    Cómo llegar →
                  </a>
                  <a
                    href={`https://instagram.com/${s.instagram}`}
                    target="_blank"
                    rel="noopener"
                    class="transition-colors hover:text-texto"
                  >
                    @{s.instagram}
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style is:global set:html={cssSwitcher}></style>
