---
// "Pide aquí", separado por sucursal: cada local tiene su propio WhatsApp
// y sus propias apps. Un solo botón para las dos sería un pedido perdido.
//
// Va en las tres páginas (portada, /carta y /bar): quien llega al final
// de la carta con hambre tiene que poder pedir sin volver al inicio.
//
// Cada botón lleva el logotipo y el color de marca real de la app. Los de
// Rappi y PedidosYa son los íconos oficiales de sus apps (ver iconoApp en
// imagenes.js); el de WhatsApp va como SVG inline porque es monocromo y
// así se pinta con el color del texto del botón.
import { Image } from "astro:assets";
import { sucursales, linkWhatsapp } from "../../data/negocio.js";
import { iconoApp } from "../../data/imagenes.js";

// clave en sucursal.canales → cómo se pinta el botón. Clases literales
// para que Tailwind las vea en el código fuente. No trabajan con Uber
// Eats, así que no está en la lista.
//
// Los colores están muestreados del propio ícono de cada app, no sacados
// de su web: así el badge del logo se funde con el botón en vez de verse
// como un cuadrito pegado encima.
const APPS = {
  whatsapp: { nombre: "WhatsApp", clase: "bg-[#25D366] text-black" },
  rappi: { nombre: "Rappi", clase: "bg-[#FF7175] text-black" },
  // El rojo del ícono es #FF0051, pero con texto blanco encima da 3,9:1 y
  // WCAG AA pide 4,5. Mismo matiz, 10% más oscuro: 4,7:1. La diferencia
  // con el badge del logo es imperceptible; la de leerlo, no.
  pedidosya: { nombre: "PedidosYa", clase: "bg-[#E60049] text-white" },
};

/** WhatsApp siempre; las apps solo si el dueño nos pasó el link. */
const canalesDe = (s) => [
  { ...APPS.whatsapp, app: "whatsapp", href: linkWhatsapp(s) },
  ...Object.entries(s.canales)
    .filter(([, url]) => url)
    .map(([app, url]) => ({ ...APPS[app], app, href: url })),
];
---

<section id="pedir" class="border-t border-borde bg-superficie">
  <div class="mx-auto max-w-5xl px-5 py-16">
    <header class="mb-10 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-marca-texto">Delivery</p>
      <h2 class="titulo-carta mt-2 text-4xl font-semibold sm:text-5xl">
        Pide aquí
      </h2>
      <p class="mx-auto mt-4 max-w-md text-texto-suave">
        Elige tu sucursal. Por WhatsApp pagas el precio de la carta: las apps
        cobran comisión.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      {
        sucursales.map((s) => (
          <div class="rounded-suave border border-borde p-6">
            <h3 class="titulo-carta text-2xl font-semibold">{s.nombre}</h3>
            <p class="mt-1 text-sm text-texto-suave">
              {s.direccion}, {s.comuna}
            </p>

            <ul class="mt-5 space-y-3">
              {canalesDe(s).map((canal) => (
                <li>
                  <a
                    href={canal.href}
                    target="_blank"
                    rel="noopener"
                    class:list={[
                      "flex items-center justify-center gap-2.5 rounded-suave px-5 py-3 text-center font-semibold transition-opacity hover:opacity-90",
                      canal.clase,
                    ]}
                  >
                    {canal.app === "whatsapp" ? (
                      <svg
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                        class="shrink-0"
                      >
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
                      </svg>
                    ) : (
                      <Image
                        src={iconoApp[canal.app]}
                        alt=""
                        width={22}
                        height={22}
                        densities={[1, 2]}
                        class="shrink-0 rounded-[5px]"
                      />
                    )}
                    {canal.nombre}
                  </a>
                </li>
              ))}
            </ul>

            <p class="mt-4 text-xs leading-relaxed text-texto-suave">
              Por WhatsApp pagas el precio de la carta. En las apps el precio
              viene con su comisión.
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
