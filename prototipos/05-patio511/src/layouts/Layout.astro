---
// Marco de todas las páginas: el <head> completo, el header y el footer.
// El contenido único de cada página entra por el <slot />.
import "@fontsource-variable/jost";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { negocio } from "../data/negocio.js";
import { schemaRestaurantes, schemaFaq } from "../data/schema.js";

interface Props {
  titulo?: string;
  descripcion?: string;
  /** El FAQPage va SOLO donde está el acordeón: repetirlo en cada página
   *  es contenido duplicado y Google lo penaliza. */
  conFaq?: boolean;
  /** "noche" apaga y satura el turquesa. Lo usa /bar. */
  tono?: "dia" | "noche";
}

const {
  titulo = `${negocio.nombre} — ${negocio.bajada}`,
  descripcion = negocio.seo.descripcion,
  conFaq = false,
  tono = "dia",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImagen = new URL(negocio.seo.ogImagen, Astro.site);
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta name="theme-color" content="#010302" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph: esto es lo que se ve al mandar el link por WhatsApp.
         Sin esto el link llega gris y sin foto, y nadie lo abre. -->
    <meta property="og:type" content="restaurant" />
    <meta property="og:site_name" content={negocio.nombre} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:image" content={ogImagen} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_CL" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Datos estructurados: un Restaurant por sucursal, con su horario
         y su dirección. Dos fichas en Google, no una. -->
    {
      schemaRestaurantes().map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    }
    {
      conFaq && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(schemaFaq())}
        />
      )
    }
  </head>

  <body data-tono={tono}>
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-suave focus:bg-marca focus:px-4 focus:py-2 focus:font-semibold focus:text-fondo"
    >
      Saltar al contenido
    </a>

    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />
  </body>
</html>
