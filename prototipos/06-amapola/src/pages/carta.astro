---
import Layout from "../layouts/Layout.astro";
import Carta from "../components/secciones/Carta.astro";
import { negocio } from "../data/negocio.js";
---

<Layout
  titulo={`Carta — ${negocio.marca}, ${negocio.comuna}`}
  descripcion="Carta completa de Amapola: tortas por porción y enteras, kuchen sureños, pie de limón y tés. Con sus sabores y precios. Pide por WhatsApp."
>
  <header class="border-b border-borde px-5 py-12 text-center">
    <p class="text-xs uppercase tracking-[0.3em] text-marca-texto">Amapola</p>
    <h1 class="titulo-carta mt-2 text-4xl font-semibold sm:text-5xl">La carta</h1>
    <p class="mx-auto mt-4 max-w-lg text-texto-suave">
      Recetas sureñas de familia. Pidiendo por WhatsApp no pagas comisión de app.
    </p>
  </header>

  <Carta />
</Layout>
