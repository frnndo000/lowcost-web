---
import { negocio, textoDias, linkWhatsapp } from "../data/negocio.js";
import Logo from "./Logo.astro";
---

<footer class="border-t border-borde bg-superficie">
  <div class="mx-auto grid max-w-5xl gap-8 px-5 py-12 sm:grid-cols-3">
    <div class="space-y-2">
      <Logo class="h-11" />
      <p class="text-sm text-texto-suave">{negocio.bajada}</p>
      <p class="text-sm text-texto-suave">{negocio.comuna}, Región de {negocio.region}</p>
    </div>

    <div class="space-y-1">
      <h2 class="mb-2 text-xs uppercase tracking-widest text-marca-texto">
        Dónde estamos
      </h2>
      <address class="text-sm text-texto-suave">
        {negocio.direccion}
        <br />
        {negocio.comuna}
      </address>
      <p>
        <a
          href={linkWhatsapp()}
          target="_blank"
          rel="noopener"
          class="text-sm transition-colors hover:text-marca-texto"
        >
          WhatsApp +{negocio.whatsapp}
        </a>
      </p>
      <p>
        <a
          href={`https://instagram.com/${negocio.instagram}`}
          target="_blank"
          rel="noopener"
          class="text-sm text-texto-suave transition-colors hover:text-texto"
        >
          @{negocio.instagram}
        </a>
      </p>
    </div>

    <div class="space-y-1">
      <h2 class="mb-2 text-xs uppercase tracking-widest text-texto-suave">
        Horario
      </h2>
      <ul class="space-y-1">
        {
          negocio.horario.map((bloque) => (
            <li class="flex justify-between gap-4 text-sm">
              <span class="text-texto">{textoDias(bloque.dias)}</span>
              <span class="tabular-nums text-texto-suave">
                {bloque.abre} – {bloque.cierra}
              </span>
            </li>
          ))
        }
      </ul>
      <p class="pt-2 text-xs text-texto-suave">
        También en Rappi, PedidosYa y Uber Eats.
      </p>
    </div>
  </div>

  <div
    class="border-t border-borde px-5 py-6 text-center text-xs text-texto-suave"
  >
    <p>&copy; {new Date().getFullYear()} {negocio.marca} · {negocio.comuna}</p>
    <p class="mt-1">
      Sitio por <a href="#" class="underline underline-offset-4 hover:text-texto">Hustlewebs</a>
    </p>
  </div>
</footer>
