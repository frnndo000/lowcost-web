---
// Portada. El fondo es un carrusel de fotos de las tortas, con crossfade
// en CSS puro —imágenes apiladas y opacity animada, cero JavaScript—,
// respetando la línea del proyecto (menú, FAQ e índice también son sin JS).
import { Image } from "astro:assets";
import Logo from "../Logo.astro";
import { negocio, linkWhatsapp } from "../../data/negocio.js";
import { fotosHero } from "../../data/imagenes.js";
---

<section id="inicio" class="relative overflow-hidden border-b border-borde">
  <div class="absolute inset-0">
    {
      fotosHero.map((img, i) => (
        <Image
          src={img.foto}
          alt=""
          aria-hidden="true"
          widths={[768, 1080, Math.min(img.ancho, 1440)]}
          sizes="100vw"
          width={img.ancho}
          height={img.alto}
          quality={90}
          loading={i === 0 ? "eager" : "lazy"}
          class="hero-slide absolute inset-0 h-full w-full object-cover"
        />
      ))
    }
  </div>

  <!-- Velos: funden la foto con el fondo claro y dan respaldo al texto.
       El peso lo lleva un scrim radial claro DETRÁS DEL TEXTO (centro),
       para que las tortas se vean vivas en los bordes. -->
  <div class="absolute inset-0 bg-marca/5"></div>
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_35%,var(--color-fondo)_100%)]"
  >
  </div>
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_60%_75%_at_center,var(--color-fondo)_20%,transparent_75%)] opacity-80"
  >
  </div>

  <div
    class="relative mx-auto flex min-h-[86svh] max-w-2xl flex-col items-center justify-center gap-5 px-5 py-16 text-center"
  >
    <Logo class="h-24 drop-shadow-sm sm:h-32" />

    <h1 class="titulo-carta text-hero font-bold text-texto drop-shadow-sm">
      Pastelería <span class="text-marca-texto">sureña</span><br />
      en {negocio.comuna}
    </h1>
    <p
      class="text-sm uppercase tracking-[0.4em] text-marca-texto sm:text-base"
    >
      Tortas · Kuchen · Postres
    </p>

    <p class="max-w-md text-balance text-lg text-texto">
      {negocio.descripcion}
    </p>

    <!-- Una acción primaria (WhatsApp, el canal preferido) y una secundaria. -->
    <div class="mt-2 flex w-full flex-col gap-3 sm:w-auto sm:flex-row">
      <a
        href={linkWhatsapp()}
        target="_blank"
        rel="noopener"
        class="rounded-suave bg-marca px-8 py-4 text-lg font-semibold text-white shadow-lg shadow-marca/25 transition-colors hover:bg-marca-hover"
      >
        Pedir por WhatsApp
      </a>
      <a
        href="/carta"
        class="rounded-suave border border-borde bg-fondo/60 px-8 py-4 text-lg font-semibold backdrop-blur-sm transition-colors hover:border-marca"
      >
        Ver la carta
      </a>
    </div>

    <p class="mt-1 text-sm text-texto-suave">
      {negocio.direccion}, {negocio.comuna}
    </p>
  </div>
</section>

<style>
  /* Carrusel por crossfade, sin JavaScript: las 3 fotos van apiladas y
     comparten el mismo keyframe de opacidad, desfasado T/3 (6 s) en cada
     una con animation-delay. El navegador funde una en otra solo.
     Opacidad tope 0.85: la legibilidad la resuelve el scrim del centro. */
  .hero-slide {
    opacity: 0;
    animation: carrusel 18s linear infinite;
  }
  .hero-slide:nth-child(1) {
    animation-delay: 0s;
  }
  .hero-slide:nth-child(2) {
    animation-delay: -6s;
  }
  .hero-slide:nth-child(3) {
    animation-delay: -12s;
  }

  /* Fundidos anchos para que en el cruce las dos fotos estén visibles a la
     vez y nunca haya un frame en blanco. */
  @keyframes carrusel {
    0% {
      opacity: 0.85;
    }
    28% {
      opacity: 0.85;
    }
    38% {
      opacity: 0;
    }
    90% {
      opacity: 0;
    }
    100% {
      opacity: 0.85;
    }
  }

  /* Sin animación (reduced-motion): que quede UNA foto visible. */
  @media (prefers-reduced-motion: reduce) {
    .hero-slide {
      opacity: 0;
    }
    .hero-slide:first-child {
      opacity: 0.85;
    }
  }
</style>
