---
// "Pedir y encargos": cómo comprar. Un solo local, sin switcher.
// Jerarquía (refactoring-ui): WhatsApp es el único botón relleno —canal
// preferido, sin comisión—; las apps de delivery van como fantasma.
import { negocio, linkWhatsapp } from "../../data/negocio.js";

const NOMBRE_APP: Record<string, string> = {
  rappi: "Rappi",
  pedidosya: "PedidosYa",
  ubereats: "Uber Eats",
};
const apps = Object.entries(negocio.canales)
  .filter(([, url]) => url)
  .map(([app, url]) => ({ url, nombre: NOMBRE_APP[app] ?? app }));

const iconoWhatsapp =
  "M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z";
---

<section id="pedir" class="border-t border-borde">
  <div class="mx-auto grid max-w-5xl gap-10 px-5 py-16 sm:py-20 lg:grid-cols-2">
    <!-- Pedir -->
    <div class="mx-auto w-full max-w-md text-center lg:mx-0 lg:text-left">
      <h2 class="titulo-carta text-titulo">Haz tu pedido</h2>
      <p class="mt-3 text-texto-suave">
        Escríbenos directo por WhatsApp: te tomamos el pedido y coordinamos
        retiro o despacho. Sin comisiones de por medio.
      </p>

      <a
        href={linkWhatsapp()}
        target="_blank"
        rel="noopener"
        class="mt-6 flex items-center justify-center gap-2.5 rounded-suave bg-[#25D366] px-5 py-4 text-lg font-semibold text-black shadow-lg shadow-[#25D366]/20 transition-transform hover:-translate-y-0.5"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          class="shrink-0"
        >
          <path d={iconoWhatsapp} />
        </svg>
        Pedir por WhatsApp
      </a>

      {
        apps.length > 0 && (
          <div class="mt-6">
            <p class="mb-2 text-xs uppercase tracking-[0.2em] text-texto-suave">
              También en delivery
            </p>
            <div class="flex flex-wrap justify-center gap-3 lg:justify-start">
              {apps.map((app) => (
                <a
                  href={app.url}
                  target="_blank"
                  rel="noopener"
                  class="rounded-suave border border-borde bg-superficie px-4 py-2.5 text-sm font-medium transition-colors hover:border-marca"
                >
                  {app.nombre}
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>

    <!-- Encargos y tortas personalizadas -->
    <div class="mx-auto w-full max-w-md rounded-suave border border-borde bg-superficie p-7 lg:mx-0">
      <p class="text-xs uppercase tracking-[0.3em] text-marca-texto">
        Por encargo
      </p>
      <h3 class="titulo-carta mt-1 text-sub">Tortas para tu celebración</h3>
      <p class="mt-3 text-texto-suave">
        Encarga tu torta entera en el sabor que quieras, o una torta temática en
        fondant para cumpleaños y eventos, junto a
        <a
          href={`https://instagram.com/${negocio.blooomCakes}`}
          target="_blank"
          rel="noopener"
          class="text-marca-texto hover:underline"
        >
          @{negocio.blooomCakes}
        </a>.
      </p>
      <p class="mt-3 text-sm text-texto-suave">
        Escríbenos con tu idea y la fecha; te cotizamos por WhatsApp.
      </p>
      <a
        href={linkWhatsapp("¡Hola Amapola! Quiero encargar una torta:")}
        target="_blank"
        rel="noopener"
        class="mt-5 inline-flex items-center gap-2 rounded-suave bg-marca px-5 py-3 font-semibold text-white transition-colors hover:bg-marca-hover"
      >
        Cotizar mi torta
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
