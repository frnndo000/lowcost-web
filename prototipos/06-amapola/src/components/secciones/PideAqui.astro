---
// "Pide aquí": el pedido, con selector de sucursal. Antes se veían las dos
// tarjetas a la vez (dos WhatsApp, dos sets de apps), lo que duplicaba la
// "doble sucursal". Ahora hay un toggle Reñaca | Quilpué y se muestra UNA a
// la vez, sin perder la presencia de la sección.
//
// El switcher es CSS puro, sin JS (misma línea del proyecto): unos `radio`
// ocultos + `:has()` que revela el panel de la sucursal marcada. Las reglas
// se generan desde el array `sucursales`, así que agregar una tercera es
// agregar datos, no tocar el componente. Los dos paneles quedan en el HTML
// (Google ve las dos), solo se oculta el no seleccionado con CSS.
//
// Jerarquía del pedido (refactoring-ui): WhatsApp es el único botón relleno
// —canal preferido, sin comisión—; Rappi/PedidosYa van como fantasma.
import { Image } from "astro:assets";
import { sucursales, linkWhatsapp } from "../../data/negocio.js";
import { iconoApp } from "../../data/imagenes.js";

const NOMBRE_APP = { rappi: "Rappi", pedidosya: "PedidosYa" };

const appsDe = (s) =>
  Object.entries(s.canales)
    .filter(([, url]) => url)
    .map(([app, url]) => ({ app, url, nombre: NOMBRE_APP[app] }));

const iconoWhatsapp =
  "M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z";

// Regla CSS por sucursal: cuando su radio está marcado, se muestra su panel.
// Global (set:html no se puede scopear); el prefijo .sel-pedir la aísla.
const cssSwitcher = sucursales
  .map(
    (s) =>
      `.sel-pedir:has(input[value="${s.id}"]:checked) [data-panel="${s.id}"]{display:block}`,
  )
  .join("\n");
---

<section id="pedir" class="border-t border-borde">
  <div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <header class="max-w-md">
        <h2 class="titulo-carta text-titulo">Pide aquí</h2>
        <p class="mt-3 text-texto-suave">
          Elige tu sucursal. Por WhatsApp pagas el precio de la carta; las apps
          cobran comisión.
        </p>
      </header>

      <div class="sel-pedir w-full max-w-md">
      {/* Pestañas: radios ocultos, el <span> se colorea al estar marcado. */}
      <fieldset class="mb-6">
        <legend class="sr-only">Elige la sucursal</legend>
        <div class="inline-flex rounded-full border border-borde p-1">
          {
            sucursales.map((s, i) => (
              <label class="cursor-pointer">
                <input
                  type="radio"
                  name="sel-pedir"
                  value={s.id}
                  checked={i === 0}
                  class="peer sr-only"
                />
                <span class="block rounded-full px-5 py-2 text-sm font-medium text-texto-suave transition-colors peer-checked:bg-marca peer-checked:font-semibold peer-checked:text-fondo peer-focus-visible:ring-2 peer-focus-visible:ring-marca-texto">
                  {s.nombre}
                </span>
              </label>
            ))
          }
        </div>
      </fieldset>

      {
        sucursales.map((s) => {
          const apps = appsDe(s);
          return (
            <div
              data-panel={s.id}
              class="hidden rounded-suave border border-borde bg-superficie p-6 shadow-lg shadow-black/20 sm:p-7"
            >
              <p class="text-sm text-texto-suave">
                {s.direccion}, {s.comuna}
              </p>

              <a
                href={linkWhatsapp(s)}
                target="_blank"
                rel="noopener"
                class="mt-5 flex items-center justify-center gap-2.5 rounded-suave bg-[#25D366] px-5 py-4 text-lg font-semibold text-black shadow-lg shadow-[#25D366]/20 transition-transform hover:-translate-y-0.5"
              >
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  class="shrink-0"
                >
                  <path d={iconoWhatsapp} />
                </svg>
                Pedir por WhatsApp
              </a>
              <p class="mt-2 text-center text-xs text-texto-suave">
                Precio de la carta, sin comisión.
              </p>

              {apps.length > 0 && (
                <div class="mt-5">
                  <p class="mb-2 text-xs uppercase tracking-[0.2em] text-texto-suave">
                    También en
                  </p>
                  <div class="grid grid-cols-2 gap-3">
                    {apps.map((app) => (
                      <a
                        href={app.url}
                        target="_blank"
                        rel="noopener"
                        class="flex items-center justify-center gap-2 rounded-suave border border-borde bg-fondo/40 px-4 py-2.5 text-sm font-medium transition-colors hover:border-marca"
                      >
                        <Image
                          src={iconoApp[app.app]}
                          alt=""
                          width={18}
                          height={18}
                          densities={[1, 2]}
                          class="shrink-0 rounded-[4px]"
                        />
                        {app.nombre}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          );
        })
      }
      </div>
    </div>
  </div>
</section>

<style is:global set:html={cssSwitcher}></style>
