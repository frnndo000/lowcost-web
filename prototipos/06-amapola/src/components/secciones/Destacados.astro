---
// La portada sí lleva fotos: en repostería la foto es el producto.
// La lista de /carta va sin ellas a propósito. Nada escondido tras hover:
// todo el texto se lee siempre, también en móvil.
import { Image } from "astro:assets";
import { destacados, clp } from "../../data/carta.js";
import { fotoDestacado } from "../../data/imagenes.js";
---

<section id="destacados" class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
  <header class="mb-10 max-w-xl">
    <h2 class="titulo-carta text-titulo">Las más pedidas</h2>
    <p class="mt-3 text-texto-suave">
      Recetas de familia, hechas como en casa. Estas nunca fallan.
    </p>
  </header>

  <ul class="grid gap-5 sm:grid-cols-3">
    {
      destacados.map((item) => {
        const imagen = fotoDestacado[item.id as keyof typeof fotoDestacado];
        return (
          <li>
            <a
              href={item.donde}
              class="group flex h-full flex-col overflow-hidden rounded-suave border border-borde bg-superficie transition-colors hover:border-marca"
            >
              <div class="aspect-4/3 overflow-hidden">
                <Image
                  src={imagen.foto}
                  alt={imagen.alt}
                  widths={[300, 600]}
                  sizes="(min-width: 640px) 33vw, 100vw"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>

              <div class="flex flex-1 flex-col gap-1 p-5">
                <div class="flex items-baseline justify-between gap-3">
                  <h3 class="titulo-carta text-item">{item.titulo}</h3>
                  <span class="shrink-0 font-semibold tabular-nums text-precio">
                    {clp(item.precio)}
                  </span>
                </div>
                <p class="text-sm leading-snug text-texto-suave">{item.texto}</p>
                <span class="mt-auto pt-3 text-sm text-marca-texto">
                  Ver en la carta{" "}
                  <span class="ml-0.5 inline-block transition-transform group-hover:translate-x-1">
                    →
                  </span>
                </span>
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>
</section>
