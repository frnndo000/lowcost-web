---
// Prueba social real: la valoración de Uber Eats (4,7★ con +1.000 reseñas).
// Es un activo que Instagram no muestra y que da confianza de compra.
import { negocio } from "../../data/negocio.js";
const { valoracion } = negocio;
const estrellasLlenas = Math.round(parseFloat(valoracion.estrellas.replace(",", ".")));
---

{
  valoracion && (
    <section aria-label="Valoración" class="border-y border-borde bg-marca/5">
      <div class="mx-auto flex max-w-5xl flex-col items-center gap-3 px-5 py-10 text-center sm:flex-row sm:justify-center sm:gap-8">
        <div class="flex items-center gap-3">
          <span class="titulo-carta text-5xl text-marca-texto">
            {valoracion.estrellas}
          </span>
          <div class="text-left">
            <div class="flex gap-0.5" aria-hidden="true">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill={i < estrellasLlenas ? "currentColor" : "none"}
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="text-marca"
                >
                  <path d="M12 2l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6L12 17.8 5.9 20.2l1.2-6.6L2.3 9l6.6-.9L12 2z" />
                </svg>
              ))}
            </div>
            <p class="mt-1 text-sm text-texto-suave">
              {valoracion.resenas} valoraciones en {valoracion.fuente}
            </p>
          </div>
        </div>

        <p class="max-w-sm text-balance text-texto-suave">
          Miles de clientes ya probaron nuestras tortas y kuchen. Sabor sureño,
          porciones generosas.
        </p>
      </div>
    </section>
  )
}
