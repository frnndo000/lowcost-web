---
// La puerta de entrada a la carta completa. Antes vivía escondida al final
// de un Linktree → Google Drive caído; acá está a un clic.
import { Image } from "astro:assets";
import { categorias } from "../../data/carta.js";
import { fotoCarta } from "../../data/imagenes.js";

const total = categorias.reduce((n, c) => n + c.platos.length, 0);
---

<section class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
  <a
    href="/carta"
    class="group relative flex h-72 items-end overflow-hidden rounded-suave border border-borde transition-colors hover:border-marca sm:h-80"
  >
    <Image
      src={fotoCarta.foto}
      alt={fotoCarta.alt}
      widths={[600, 1200]}
      sizes="(min-width: 1024px) 1024px, 100vw"
      class="absolute inset-0 h-full w-full object-cover opacity-70 transition-transform duration-500 group-hover:scale-105"
    />
    <div
      class="absolute inset-0 bg-linear-to-t from-fondo via-fondo/70 to-transparent"
    >
    </div>

    <div class="relative w-full p-7 sm:p-9">
      <p class="text-xs uppercase tracking-[0.3em] text-marca-texto">Carta</p>
      <h2 class="titulo-carta mt-1 text-3xl font-semibold sm:text-4xl">
        Todas nuestras tortas y kuchen
      </h2>
      <p class="mt-2 max-w-md text-sm text-texto-suave">
        Tortas por porción o enteras, kuchen sureños, pie de limón y tés. Con
        sus sabores y precios.
      </p>
      <p class="mt-3 text-sm">
        Ver los {total} productos{" "}
        <span class="inline-block transition-transform group-hover:translate-x-1">
          →
        </span>
      </p>
    </div>
  </a>
</section>
