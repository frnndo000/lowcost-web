---
// Wordmark de la marca (imagen "Amapola · Pastelería Sureña", con el fondo
// blanco recortado a transparente). El tamaño se controla con una clase de
// alto (h-*); el ancho se ajusta solo manteniendo la proporción.
import { Image } from "astro:assets";
import { logo } from "../data/imagenes.js";

interface Props {
  class?: string;
}
const { class: clase = "h-10" } = Astro.props;
---

<Image
  src={logo}
  alt="Amapola · Pastelería Sureña"
  loading="eager"
  densities={[1, 2]}
  class:list={["w-auto object-contain", clase]}
/>
