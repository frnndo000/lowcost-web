---
// Marco de todas las páginas: el <head> completo, el header y el footer.
// El contenido único de cada página entra por el <slot />.
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { negocio } from "../data/negocio.js";
import { schemaNegocio, schemaFaq } from "../data/schema.js";

interface Props {
  titulo?: string;
  descripcion?: string;
  /** El FAQPage va SOLO donde está el acordeón: repetirlo en cada página
   *  es contenido duplicado y Google lo penaliza. */
  conFaq?: boolean;
}

const {
  titulo = `${negocio.marca} — ${negocio.bajada} en ${negocio.comuna}`,
  descripcion = negocio.seo.descripcion,
  conFaq = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImagen = new URL(negocio.seo.ogImagen, Astro.site);
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Fuentes autohospedadas: body (Hanken) y títulos (Bricolage). -->
    <link
      rel="preload"
      href="/fonts/hanken-grotesk-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/bricolage-grotesque-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta name="theme-color" content="#c2185b" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph: esto es lo que se ve al mandar el link por WhatsApp. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={negocio.marca} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:image" content={ogImagen} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_CL" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Datos estructurados: un Bakery con horario, dirección y valoración.
         is:inline porque es JSON estático, no un script a procesar. -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schemaNegocio())}
    />
    {
      conFaq && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(schemaFaq())}
        />
      )
    }
  </head>

  <body>
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-suave focus:bg-marca focus:px-4 focus:py-2 focus:font-semibold focus:text-white"
    >
      Saltar al contenido
    </a>

    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />
  </body>
</html>
