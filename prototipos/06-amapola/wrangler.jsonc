{
  // Sirve solo la carpeta compilada (dist/), no el repo entero.
  // Sin este archivo, wrangler sube por el árbol y usa el wrangler.jsonc
  // de la raíz (name "hustlewebs", directory "."), publicando el sitio
  // equivocado y todo el repo (node_modules, .git) como assets.
  "name": "amapola",
  "compatibility_date": "2026-07-21",
  "assets": { "directory": "./dist" },
}
