---
import { Image } from "astro:assets";
import isaac from "../../assets/isaac.jpg";
const AGENDA = "https://www.gimnasioseven.com/booking-calendar/nutricionista-isaac-vi%C3%B1a-del-mar?referral=service_list_widget";
---
<section id="inicio" class="relative min-h-screen flex items-center bg-white pt-24 pb-16 overflow-hidden">

  <!-- FOTO DE FONDO (solo móvil) -->
  <div id="hero-foto" class="absolute inset-0 md:hidden will-change-transform">
  <Image src={isaac}
       alt=""
       aria-hidden="true"
       loading="eager"
       class="w-full h-full object-cover object-[center_15%]" />
  <!-- Velo: sólido abajo, transparente arriba para que el rostro se vea -->
  <div class="absolute inset-0"
     style="background: linear-gradient(to top, #fff 0%, #fff 34%, rgba(255,255,255,0.55) 45%, rgba(255,255,255,0) 58%);">
</div>
</div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-8 md:gap-16 items-center w-full pt-[45vh] md:pt-0">

    <!-- TEXTO -->
    <div>
      <h1 class="font-[Anton] text-neutral-900 uppercase leading-[0.95] text-5xl md:text-7xl mb-6">
        Nutrición<br />
        <span class="text-emerald-700">hecha</span><br />
        a tu medida
      </h1>

      <p class="inline-flex items-center gap-2 text-emerald-700 text-xs font-semibold uppercase tracking-widest mb-6">
        <span class="w-8 h-px bg-emerald-700"></span>
        Viña del Mar · Gimnasio Seven
      </p>

      <p class="text-neutral-700 text-lg leading-relaxed max-w-md mb-10">
        Olvídate de las dietas genéricas. Un plan diseñado para tu cuerpo,
        tu rutina y tus objetivos reales.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href={AGENDA} target="_blank" rel="noopener"
           class="group bg-neutral-900 text-white px-8 py-4 rounded-full font-semibold
                  hover:bg-neutral-700 transition-all inline-flex items-center justify-center gap-2 shadow-lg">
          Agendar mi evaluación
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a href="#servicio"
           class="border border-neutral-300 bg-white/70 backdrop-blur-sm text-neutral-900 px-8 py-4 rounded-full font-semibold
                  hover:border-neutral-900 transition-all text-center">
          Cómo funciona
        </a>
      </div>
    </div>

    <!-- FOTO CON MARCO (solo escritorio) -->
    <div class="relative hidden md:block">
      <div class="absolute -inset-6 bg-emerald-50 rounded-[3rem] -rotate-3"></div>
      <Image src={isaac}
       alt="Isaac, nutricionista en Viña del Mar"
       loading="eager"
       class="relative w-full aspect-4/5 object-cover rounded-4xl shadow-xl" />
    </div>

  </div>
</section>

<script>
  const foto = document.getElementById('hero-foto');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (foto && !reduceMotion) {
    let ticking = false;

    const actualizar = () => {
      const y = window.scrollY;
      const avance = Math.min(y / window.innerHeight, 1);
      foto.style.opacity = `${1 - avance}`;
      foto.style.transform = `translate3d(0, ${y * 0.3}px, 0)`;
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(actualizar);
        ticking = true;
      }
    }, { passive: true });

    actualizar();
  }
</script>