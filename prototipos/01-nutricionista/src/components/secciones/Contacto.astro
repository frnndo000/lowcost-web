---
const AGENDA = "https://www.gimnasioseven.com/booking-calendar/nutricionista-isaac-vi%C3%B1a-del-mar?referral=service_list_widget";
const TELEFONO = "nro";
const MENSAJE = encodeURIComponent("Hola Isaac, quiero agendar una evaluación nutricional.");
const INSTAGRAM = "https://www.instagram.com/nutri_isaac/";
---
<section id="contacto" class="bg-neutral-50 py-28 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="max-w-2xl mb-14">
      <p class="text-emerald-700 text-xs font-semibold uppercase tracking-widest mb-4">Contacto</p>
      <h2 class="text-neutral-900 font-extrabold text-4xl md:text-5xl leading-tight mb-4">
        Nos vemos en consulta
      </h2>
      <p class="text-neutral-600 text-lg">
        Atiendo en Gimnasio Seven, Viña del Mar. Agenda directamente en el calendario
        o escríbeme al <a href={`https://wa.me/${TELEFONO}?text=${MENSAJE}`} target="_blank" rel="noopener" class="text-emerald-700 hover:underline">WhatsApp</a> si tienes dudas antes de agendar.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

      <!-- Datos -->
      <div class="space-y-4">

        <div class="group bg-white border border-neutral-200 rounded-3xl p-7 hover:border-emerald-700/30 hover:shadow-lg transition-all duration-300">
          <p class="text-[11px] uppercase tracking-widest text-neutral-400 mb-2">Ubicación</p>
          <p class="text-neutral-900 font-bold text-lg mb-1">Gimnasio Seven</p>
          <p class="text-neutral-600 text-sm">Bellavista 237, Viña del Mar, Valparaíso</p>
        </div>

        <div class="group bg-white border border-neutral-200 rounded-3xl p-7 hover:border-emerald-700/30 hover:shadow-lg transition-all duration-300">
        <p class="text-[11px] uppercase tracking-widest text-neutral-400 mb-4">Horario de atención</p>

      <div class="flex items-baseline gap-3 mb-4">
        <p class="text-neutral-900 font-bold text-lg">Lunes y jueves</p>
      </div>

      <div class="flex flex-wrap gap-2 mb-5">
        <span class="text-xs font-semibold text-neutral-700 bg-neutral-100 px-3 py-1.5 rounded-full">16:00 – 17:00</span>
        <span class="text-xs font-semibold text-neutral-700 bg-neutral-100 px-3 py-1.5 rounded-full">17:00 – 18:00</span>
        <span class="text-xs font-semibold text-neutral-700 bg-neutral-100 px-3 py-1.5 rounded-full">18:00 – 19:00</span>
      </div>

      <p class="text-neutral-500 text-xs leading-relaxed border-t border-neutral-100 pt-4">
        Tres cupos por jornada. Revisa la disponibilidad y reserva en el calendario del Gimnasio Seven.
      </p>
    </div>

        <div class="grid grid-cols-2 gap-4">
          <a href={`https://wa.me/${TELEFONO}?text=${MENSAJE}`} target="_blank" rel="noopener"
             class="bg-white border border-neutral-200 rounded-3xl p-6 text-center hover:border-emerald-700 hover:-translate-y-1 transition-all duration-300">
            <p class="text-neutral-900 font-bold">WhatsApp</p>
            <p class="text-neutral-500 text-xs mt-1">Dudas rápidas</p>
          </a>
          <a href={INSTAGRAM} target="_blank" rel="noopener"
             class="bg-white border border-neutral-200 rounded-3xl p-6 text-center hover:border-emerald-700 hover:-translate-y-1 transition-all duration-300">
            <p class="text-neutral-900 font-bold">Instagram</p>
            <p class="text-neutral-500 text-xs mt-1">@nutri_isaac</p>
          </a>
        </div>

        <a href={AGENDA} target="_blank" rel="noopener"
           class="group block bg-neutral-900 text-white rounded-3xl p-7 hover:bg-neutral-800 transition-colors">
          <p class="text-[11px] uppercase tracking-widest text-neutral-400 mb-2">Reservar</p>
          <p class="font-bold text-lg flex items-center gap-2">
            Ver disponibilidad y agendar
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </p>
        </a>
      </div>

      <!-- Mapa -->
      <div class="rounded-3xl overflow-hidden border border-neutral-200 min-h-100">
        <iframe
          src="https://www.google.com/maps?q=Gimnasio+Seven+Vi%C3%B1a+del+Mar&output=embed"
          width="100%" height="100%" style="border:0; min-height:400px;"
          allowfullscreen="" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Gimnasio Seven en Viña del Mar">
        </iframe>
      </div>

    </div>
  </div>
</section>