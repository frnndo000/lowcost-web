---
const { titulo, descripcion, detalle, numero } = Astro.props;
---
<article class="group relative overflow-hidden bg-neutral-900 border border-neutral-800 p-8 h-80
                transition-all duration-500 hover:border-white/40 hover:-translate-y-2
                hover:shadow-[0_0_50px_rgba(255,255,255,0.06)] cursor-default">

  <!-- Capa holograma -->
  <div class="absolute inset-0 bg-linear-to-br from-white/[0.07] via-transparent to-transparent
              opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

  <!-- Número gigante de fondo -->
  <span class="absolute -top-4 -right-2 font-[Anton] text-[8rem] leading-none text-white/4
               transition-all duration-500 group-hover:text-white/9 group-hover:scale-110">
    {numero}
  </span>

  <div class="relative h-full flex flex-col">
    <h3 class="font-[Anton] text-2xl text-white uppercase mb-3 leading-tight">{titulo}</h3>
    <p class="text-neutral-400 text-sm leading-relaxed">{descripcion}</p>

    <!-- Detalle oculto que sube al hacer hover -->
    <div class="mt-auto translate-y-6 opacity-0
                group-hover:translate-y-0 group-hover:opacity-100
                transition-all duration-500 delay-75">
      <p class="text-sm text-white/70 border-l-2 border-white pl-4">{detalle}</p>
    </div>
  </div>

  <!-- Línea que se dibuja abajo -->
  <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-white
              group-hover:w-full transition-all duration-700"></div>
</article>