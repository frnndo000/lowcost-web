---
// ↑ Esto es el "frontmatter". Todo lo que va entre las --- es
// JavaScript que corre en el SERVIDOR, en build. No llega al navegador.

// 1. Importas el CSS global UNA vez, acá. Astro lo inyecta en todas
//    las páginas que usen este layout.
import "../styles/global.css";

// 2. Props: los datos que cada página le pasa a este layout.
//    Aquí los "desempaquetas" desde Astro.props.
const { titulo, descripcion } = Astro.props;
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- 3. Interpolación: {variable} inserta el valor de la prop -->
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
  </head>

  <body>
    <!-- HEADER: el mismo que tenías en Tailwind, ahora vive UNA sola
         vez y se reutiliza en toda página que use este Layout. -->
    <header
      class="flex flex-col items-center gap-4 border-b border-borde p-6 md:flex-row md:justify-between"
    >
      <a class="shrink-0" href="/">
        <img
          src="/imagenes/logobarber.png"
          alt="Barbería El Chute"
          width="150"
          height="50"
        />
      </a>

      <nav>
        <ul
          class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 md:justify-end"
        >
          <li><a href="#servicios">Servicios</a></li>
          <li><a href="#horario">Horario</a></li>
          <li><a href="#nosotros">Nosotros</a></li>
          <li><a href="#ubicacion">Ubicación</a></li>
          <li>
            <a
              class="inline-block rounded-sm bg-acento px-8 py-4 font-bold text-fondo transition-colors hover:bg-acento-hover hover:text-fondo"
              href="#agendar">Agendar hora</a
            >
          </li>
        </ul>
      </nav>
    </header>

    <!-- 4. <slot /> = el hueco donde Astro mete el contenido único
         de cada página. Es lo que reemplaza al copy-paste. -->
    <main class="mx-auto max-w-lectura px-6 md:px-4">
      <slot />
    </main>

    <footer class="border-t border-borde px-6 py-8 text-center">
      <p>
        Míranos en Instagram:
        <a
          href="https://instagram.com/barberiaelchute"
          target="_blank"
          rel="noopener">@barberiaelchute</a
        >
      </p>
      <p class="text-sm text-texto-suave">&copy; 2026 Barbería El Chute.</p>
    </footer>
  </body>
</html>
